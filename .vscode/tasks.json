{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start AcuBuddy Server",
      "type": "shell",
      "command": "uvicorn",
      "args": [
        "server:app",
        "--host", "127.0.0.1",
        "--port", "5000",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
